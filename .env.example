# ══════════════════════════════════════════════════════
#  CHAOS-1 // SURVIVAL INTELLIGENCE — Environment Config
#  cp .env.example .env  then fill your values
# ══════════════════════════════════════════════════════

# ── Choose your AI provider ─────────────────────────────
# Options: anthropic | deepseek | ollama
AI_PROVIDER=anthropic

# ── Anthropic (Claude) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# ── DeepSeek ────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXX

# ── Ollama (LOCAL — no internet needed) ─────────────────
# Install: https://ollama.com  then: ollama pull mistral
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# Other good local models: llama3, phi3, gemma2, qwen2
